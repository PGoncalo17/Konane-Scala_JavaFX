<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #3e2723;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Project.InitialMenu">
   <children>
      <VBox alignment="CENTER" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <Label text="KONANE GAME" textFill="#d7ccc8">
               <font>
                  <Font name="Serif Bold" size="42.0" />
               </font>
            </Label>
            
            <Separator maxWidth="450.0" style="-fx-opacity: 0.3;" />

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="DimensionID" minHeight="45.0" minWidth="140.0" mnemonicParsing="false" onAction="#OnDimensionClicked" style="-fx-background-color: #0a1c83; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="SET DIMENSIONS">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>
                  
                  <Button fx:id="TimerButtonID" minHeight="45.0" minWidth="140.0" mnemonicParsing="false" onAction="#OnTimerClicked" style="-fx-background-color: #5c5958; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="SET TIMER">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>

                  <Button fx:id="StartGameID" minHeight="45.0" minWidth="140.0" mnemonicParsing="false" onAction="#OnStartGameClicked" style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="START GAME">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Button>

                  <Button fx:id="QuitID1" minHeight="45.0" minWidth="100.0" mnemonicParsing="false" onAction="#OnQuit1Clicked" style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="QUIT">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>
               </children>
            </HBox>

            <!-- Start a new game/Continue last game -->
            <VBox fx:id="StartNewGameId" alignment="CENTER" spacing="15.0" visible="false">
               <children>
                  <Label fx:id="ResumeGameLabel" text="You have an unfinished game!" textFill="#ffeb3b">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <Button fx:id="BtnContinue" onAction="#onActionContinue" prefHeight="45.0" prefWidth="140.0" 
                              style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 15;" text="CONTINUE">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Button fx:id="BtnIgnore" onAction="#onActionIgnore" prefHeight="45.0" prefWidth="140.0" 
                              style="-fx-background-color: #757575; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 15;" text="IGNORE">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                     </children>
                  </HBox>
                  <Separator maxWidth="300.0" style="-fx-opacity: 0.2;" />
               </children>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <GridPane alignment="CENTER" hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" />
                        <ColumnConstraints halignment="LEFT" />
                     </columnConstraints>
                     <children>
                        <Label fx:id="LinesID1" text="Lines:" textFill="WHITE" visible="false">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="LinesID2" maxWidth="60.0" visible="false" GridPane.columnIndex="1" />
                        
                        <Label fx:id="ColsID1" text="Columns:" textFill="WHITE" visible="false" GridPane.rowIndex="1">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="ColsID2" maxWidth="60.0" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
                  <Button fx:id="OkDimensionButtonID" onAction="#OnOkDimensionsClicked" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #fbc02d; -fx-background-radius: 10; -fx-cursor: hand;" text="Apply Size" visible="false">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
               </children>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label fx:id="TimerLabel" text="Turn Time (sec):" textFill="WHITE" visible="false">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="TimerField" maxWidth="60.0" promptText="ex: 30" visible="false" />
                     </children>
                  </HBox>
                  <Button fx:id="OkTimerButtonID" onAction="#OnOkTimerClicked" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #fbc02d; -fx-background-radius: 10; -fx-cursor: hand;" text="Apply Timer" visible="false">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Button>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>